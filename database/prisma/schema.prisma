generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
  PREMIUM
}

enum UserRole {
  USER
  MOD
  ADMIN
  OWNER
}

enum InfractionType {
  WARN
  MUTE
  KICK
  BAN
  UNBAN
  UNMUTE
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  discordId     String   @unique
  username      String
  discriminator String   @default("0")
  avatarUrl     String?
  email         String?  @unique
  plan             Plan     @default(FREE)
  stripeCustomerId String?  @unique
  stripeSubId      String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  guildMemberships    GuildMember[]
  subscriptions       Subscription[]
  issuedInfractions   Infraction[]   @relation("ModeratorInfractions")
  receivedInfractions Infraction[]   @relation("TargetInfractions")

  @@map("users")
}

// ─── Guild ────────────────────────────────────────────────────────────────────

model Guild {
  id            String   @id @default(cuid())
  discordId     String   @unique
  name          String
  iconUrl       String?
  ownerId       String
  config        Json     @default("{}")
  activeModules String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  settings      GuildSettings?
  members       GuildMember[]
  infractions   Infraction[]
  subscriptions Subscription[]
  voiceSessions VoiceSession[]

  @@map("guilds")
}

model GuildSettings {
  guildId          String  @id
  prefix           String  @default("!")
  language         String  @default("en")
  logChannelId     String?
  welcomeChannelId String?
  welcomeMessage   String?
  modRoleId        String?
  adminRoleId      String?

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("guild_settings")
}

model GuildMember {
  userId   String
  guildId  String
  role     UserRole @default(USER)
  joinedAt DateTime @default(now())
  xp       Int      @default(0)
  level    Int      @default(0)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@id([userId, guildId])
  @@map("guild_members")
}

// ─── Subscription ─────────────────────────────────────────────────────────────

model Subscription {
  id               String    @id @default(cuid())
  userId           String
  guildId          String
  plan             Plan
  stripeCustomerId String?
  stripeSubId      String?   @unique
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([userId, guildId])
  @@index([stripeCustomerId])
  @@index([expiresAt])
  @@map("subscriptions")
}

// ─── Voice Session ────────────────────────────────────────────────────────────

model VoiceSession {
  id               String    @id @default(cuid())
  guildId          String
  userId           String?
  channelId        String?
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  interactionCount Int       @default(0)

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, startedAt])
  @@map("voice_sessions")
}

// ─── Moderation ───────────────────────────────────────────────────────────────

model Infraction {
  id              String         @id @default(cuid())
  guildId         String
  targetUserId    String
  moderatorUserId String
  type            InfractionType
  reason          String?
  expiresAt       DateTime?
  createdAt       DateTime       @default(now())

  guild     Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  target    User  @relation("TargetInfractions", fields: [targetUserId], references: [id])
  moderator User  @relation("ModeratorInfractions", fields: [moderatorUserId], references: [id])

  @@index([guildId, targetUserId])
  @@index([guildId, type])
  @@map("infractions")
}
