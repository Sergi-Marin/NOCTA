DATABASE_URL="postgresql://nocta:nocta@localhost:5432/nocta"
REDIS_URL="redis://localhost:6379"

# ─── Discord ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=""
DISCORD_CLIENT_ID=""
DISCORD_GUILD_ID=""         # Dev guild for instant slash command registration

# ─── Picovoice / Porcupine (wake word) ────────────────────────────────────────
# 1. Sign up at https://console.picovoice.ai and copy your Access Key
# 2. Create a custom "Nocta" keyword model and download the .ppn file
PICOVOICE_ACCESS_KEY=""
PORCUPINE_KEYWORD_PATH="./assets/Nocta_en_windows_v3_0_0.ppn"
PORCUPINE_SENSITIVITY="0.5"   # 0.0 (fewer false positives) – 1.0 (fewer misses)

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ─── ElevenLabs (TTS) ────────────────────────────────────────────────────────
# Find voice IDs at https://elevenlabs.io/app/voice-library
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""
ELEVENLABS_MODEL_ID="eleven_turbo_v2_5"   # turbo = lowest latency
